rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApprovedFirm() {
      return request.auth != null &&
        get(/databases/$(database)/documents/firms/$(request.auth.uid)).data.isApproved == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasValidTCPA() {
      return request.resource.data.keys().hasAll(['tcpaConsent', 'phone']) &&
        request.resource.data.tcpaConsent == true;
    }

    // ── Users Collection ──────────────────────────────────────────────────────
    // Users can only read/write their own document.
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── PI Leads (Core Revenue Asset — HIPAA Sensitive) ───────────────────────
    // - Customers: write own lead with TCPA consent
    // - Approved Firms: read anonymized portal_listings only (see below)
    // - Admin/Backend: full access via Admin SDK (bypasses these rules)
    // - CRITICAL: No firm can read raw pi_leads — only portal_listings
    match /pi_leads/{leadId} {
      allow read: if isAdmin();
      allow create: if request.auth != null && hasValidTCPA();
      allow update: if isAdmin(); // Only backend functions update scores/status
      allow delete: if isAdmin();
    }

    // ── Portal Listings (Anonymized, De-identified Lead Marketplace) ──────────
    // Firms see case summaries without PII until they purchase.
    // Backend functions create these from pi_leads after scoring.
    match /portal_listings/{caseId} {
      allow read: if isApprovedFirm() || isAdmin();
      allow write: if false; // Cloud Functions only (Admin SDK)
    }

    // ── Purchased Leads (Post-purchase PII Release) ───────────────────────────
    // After a firm purchases a lead, full data is moved here, scoped to that firm.
    match /purchased_leads/{firmId}/{leadId} {
      allow read: if isOwner(firmId) || isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ── Firms Collection ──────────────────────────────────────────────────────
    // Firms can read their own profile. Approval is admin-only.
    match /firms/{firmId} {
      allow read: if isOwner(firmId) || isAdmin();
      allow create: if request.auth != null; // Self-registration allowed
      allow update: if isAdmin(); // Only admin approves/disables firms
      allow delete: if isAdmin();
    }

    // ── Insurance Leads (Existing P&C Transfer Flow) ──────────────────────────
    match /insurance_leads/{leadId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── System Config (LVI Models, Intake Logic, AI Prompts) ─────────────────
    // Fully locked — only Admin SDK (backend) can read/write.
    match /system_config/{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Task Runs & Agent Logs ────────────────────────────────────────────────
    match /task_runs/{runId} {
      allow read: if isAdmin();
      allow write: if false; // Backend only
    }

    match /agent_tasks/{taskId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Finance Documents (Tax Vault) ─────────────────────────────────────────
    match /finance_documents/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Skill Registry ────────────────────────────────────────────────────────
    match /skill_registry/{skillId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Default: DENY ALL ─────────────────────────────────────────────────────
    // Any collection not explicitly listed is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
